# Agent Publisher

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_publisher

# Tencent Cloud (Hunyuan Image Generation)
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key

# Default LLM (can be overridden per agent)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=your_api_key
DEFAULT_LLM_BASE_URL=

# Access key for UI login and API authentication
ACCESS_KEY=agent-publisher-2024
JWT_SECRET=

# Server
HOST=0.0.0.0
PORT=9099
DEBUG=false
