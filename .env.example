# Agent Publisher

# Database
# SQLite (default for quick deployment)
DATABASE_URL=sqlite+aiosqlite:///agent_publisher.db
# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_publisher

# Tencent Cloud (Hunyuan Image Generation)
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key

# Default LLM (can be overridden per agent)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=your_api_key
DEFAULT_LLM_BASE_URL=

# Access key for admin UI login and API authentication
ACCESS_KEY=agent-publisher-2024
JWT_SECRET=

# Server
HOST=0.0.0.0
PORT=9099
DEBUG=false

# User Authentication (Skills API & Web UI Email login)
# Comma-separated email whitelist (users allowed to login via email or connect via skills API)
# These users can only see/operate their own data (accounts, agents, articles, etc.)
EMAIL_WHITELIST=user1@example.com,user2@example.com
# Comma-separated admin emails (full access to all data, can manage global settings)
# Admin emails are automatically included in the whitelist
ADMIN_EMAILS=admin@example.com
