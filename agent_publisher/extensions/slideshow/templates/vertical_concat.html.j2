<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; height: 100%; overflow: hidden; background: #000; font-family: system-ui, sans-serif; }

    /* ---- Player container ---- */
    .player {
      position: relative; width: 100%; height: 100%;
      display: flex; flex-direction: column;
    }

    /* ---- Stage: scaled 1080x1920 iframe (9:16 vertical) ---- */
    .stage {
      flex: 1; position: relative; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      background: #0a0a1a;
    }
    .stage iframe {
      border: none;
      width: 1080px; height: 1920px;
      transform-origin: center center;
    }

    /* ---- Controls bar ---- */
    .controls {
      height: 52px; background: #111;
      display: flex; align-items: center; gap: 14px;
      padding: 0 16px; color: #fff; font-size: 13px;
      user-select: none;
    }
    .controls button {
      background: none; border: none; color: #fff;
      font-size: 18px; cursor: pointer; padding: 4px 8px;
      border-radius: 4px; transition: background 0.2s;
    }
    .controls button:hover { background: rgba(255,255,255,0.15); }
    .controls button:disabled { opacity: 0.3; cursor: default; }

    /* ---- Progress bar ---- */
    .progress-bar {
      flex: 1; height: 5px; background: rgba(255,255,255,0.12);
      border-radius: 3px; cursor: pointer; position: relative;
    }
    .progress-fill {
      height: 100%; background: #3b82f6; border-radius: 3px;
      transition: width 0.3s ease;
    }
    .progress-scenes {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      display: flex;
    }
    .progress-scene-seg {
      height: 100%; border-right: 1.5px solid rgba(255,255,255,0.25);
    }
    .progress-scene-seg:last-child { border-right: none; }

    /* ---- Scene info ---- */
    .scene-info { white-space: nowrap; color: rgba(255,255,255,0.7); }

    /* ---- Fullscreen ---- */
    .player:-webkit-full-screen .controls { position: fixed; bottom: 0; left: 0; right: 0; z-index: 100; }
    .player:fullscreen .controls { position: fixed; bottom: 0; left: 0; right: 0; z-index: 100; }

    /* ---- Notes panel ---- */
    .notes-panel {
      display: none; position: fixed; bottom: 52px; left: 0; right: 0;
      background: rgba(0,0,0,0.92); color: #ccc; padding: 14px 20px;
      font-size: 15px; line-height: 1.6; max-height: 180px; overflow-y: auto;
      z-index: 50; border-top: 1px solid rgba(255,255,255,0.1);
    }
    .notes-panel.visible { display: block; }
  </style>
</head>
<body>
  <div class="player" id="player">
    <div class="stage" id="stage">
      <!-- iframe injected by JS -->
    </div>

    <div class="controls">
      <button id="btn-prev" title="上一场景">&laquo;</button>
      <button id="btn-play" title="播放/暂停">&#9654;</button>
      <button id="btn-next" title="下一场景">&raquo;</button>

      <div class="progress-bar" id="progress-bar">
        <div class="progress-fill" id="progress-fill" style="width:0%"></div>
        <div class="progress-scenes" id="progress-scenes"></div>
      </div>

      <span class="scene-info" id="scene-info">1 / {{ scenes | length }}</span>

      <button id="btn-notes" title="口播脚本">&#128196;</button>
      <button id="btn-fullscreen" title="全屏">&#x26F6;</button>
    </div>

    <div class="notes-panel" id="notes-panel"></div>
  </div>

  <script>
    (function() {
      var scenes = {{ scenes_json }};
      var currentIdx = 0;
      var isPlaying = true;
      var iframe = null;

      var stage = document.getElementById('stage');
      var btnPrev = document.getElementById('btn-prev');
      var btnPlay = document.getElementById('btn-play');
      var btnNext = document.getElementById('btn-next');
      var btnFS = document.getElementById('btn-fullscreen');
      var btnNotes = document.getElementById('btn-notes');
      var progressFill = document.getElementById('progress-fill');
      var progressBar = document.getElementById('progress-bar');
      var progressScenes = document.getElementById('progress-scenes');
      var sceneInfo = document.getElementById('scene-info');
      var notesPanel = document.getElementById('notes-panel');

      // Build progress scene dividers (each scene = 1 segment)
      scenes.forEach(function() {
        var div = document.createElement('div');
        div.className = 'progress-scene-seg';
        div.style.width = (100 / scenes.length) + '%';
        progressScenes.appendChild(div);
      });

      function scaleIframe() {
        if (!iframe) return;
        var sw = stage.clientWidth;
        var sh = stage.clientHeight;
        // Scale to fit 1080x1920 inside the viewport
        var scale = Math.min(sw / 1080, sh / 1920);
        iframe.style.transform = 'scale(' + scale + ')';
      }

      function loadScene(idx) {
        if (idx < 0 || idx >= scenes.length) return;
        currentIdx = idx;

        if (iframe) { stage.removeChild(iframe); }

        iframe = document.createElement('iframe');
        iframe.src = scenes[idx].html_file;
        iframe.setAttribute('sandbox', 'allow-scripts allow-same-origin');
        stage.appendChild(iframe);

        scaleIframe();
        updateUI();

        iframe.addEventListener('load', function() {
          if (isPlaying) {
            iframe.contentWindow.postMessage({type: 'play'}, '*');
          } else {
            iframe.contentWindow.postMessage({type: 'pause'}, '*');
          }
        });
      }

      function updateUI() {
        sceneInfo.textContent = (currentIdx + 1) + ' / ' + scenes.length;
        btnPrev.disabled = currentIdx === 0;
        btnNext.disabled = currentIdx === scenes.length - 1;
        btnPlay.innerHTML = isPlaying ? '&#10074;&#10074;' : '&#9654;';
        progressFill.style.width = ((currentIdx + 1) / scenes.length * 100) + '%';

        var sc = scenes[currentIdx];
        notesPanel.textContent = sc.notes || '';
      }

      // Listen for scene-complete from iframe
      window.addEventListener('message', function(e) {
        if (e.data && e.data.type === 'scene-complete') {
          if (currentIdx < scenes.length - 1) {
            loadScene(currentIdx + 1);
          } else {
            progressFill.style.width = '100%';
            isPlaying = false;
            updateUI();
          }
        }
      });

      btnPrev.addEventListener('click', function() { loadScene(currentIdx - 1); });
      btnNext.addEventListener('click', function() { loadScene(currentIdx + 1); });

      btnPlay.addEventListener('click', function() {
        isPlaying = !isPlaying;
        if (iframe && iframe.contentWindow) {
          iframe.contentWindow.postMessage({type: isPlaying ? 'play' : 'pause'}, '*');
        }
        updateUI();
      });

      btnFS.addEventListener('click', function() {
        var el = document.getElementById('player');
        if (el.requestFullscreen) el.requestFullscreen();
        else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
      });

      btnNotes.addEventListener('click', function() {
        notesPanel.classList.toggle('visible');
      });

      progressBar.addEventListener('click', function(e) {
        var rect = progressBar.getBoundingClientRect();
        var pct = (e.clientX - rect.left) / rect.width;
        var idx = Math.min(Math.floor(pct * scenes.length), scenes.length - 1);
        loadScene(idx);
      });

      // Keyboard
      document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowRight') { loadScene(currentIdx + 1); }
        if (e.key === 'ArrowLeft') { loadScene(currentIdx - 1); }
        if (e.key === ' ') { btnPlay.click(); e.preventDefault(); }
        if (e.key === 'f' || e.key === 'F') { btnFS.click(); }
        if (e.key === 'n' || e.key === 'N') { btnNotes.click(); }
      });

      window.addEventListener('resize', scaleIframe);

      // Start
      loadScene(0);
    })();
  </script>
</body>
</html>
