<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=1080">
  <title>{{ video_title }} - {{ scene_title }}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      width: 1080px; height: 1920px; overflow: hidden;
      font-family: "PingFang SC", "Microsoft YaHei", "Noto Sans CJK SC", "Helvetica Neue", Arial, sans-serif;
      background: #0a0a1a;
    }

    {{ theme_css }}

    /* ---- Scene container ---- */
    .scene {
      width: 1080px; height: 1920px; overflow: hidden;
      position: absolute; top: 0; left: 0;
      display: none; flex-direction: column;
      opacity: 0; transition: opacity 0.6s ease-in-out;
    }
    .scene.active {
      display: flex; opacity: 1;
    }

    /* ---- Three-zone layout ---- */
    .top-zone {
      flex: 0 0 25%; display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      text-align: center; padding: 60px 60px 20px;
      z-index: 2;
    }
    .top-zone h1 {
      font-size: 64px; font-weight: 800; color: #fff;
      line-height: 1.25; letter-spacing: -1px;
      margin-bottom: 16px;
    }
    .top-zone .subline {
      font-size: 32px; color: rgba(255,255,255,0.7);
      line-height: 1.4; font-weight: 400;
    }

    .visual-zone {
      flex: 0 0 45%; display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      margin: 0 48px; border-radius: 20px;
      position: relative; overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }
    .visual-zone .icon {
      font-size: 120px; margin-bottom: 24px;
      filter: drop-shadow(0 4px 20px rgba(0,0,0,0.3));
    }
    .visual-zone .description {
      font-size: 28px; color: rgba(255,255,255,0.8);
      text-align: center; padding: 0 40px;
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }

    .bottom-zone {
      flex: 0 0 25%; display: flex; flex-direction: column;
      justify-content: center; padding: 20px 60px 40px;
      z-index: 2;
    }
    .bottom-zone .line {
      font-size: 34px; line-height: 1.6; color: rgba(255,255,255,0.9);
      margin-bottom: 12px;
    }
    .highlight-word {
      color: var(--accent-color, #60a5fa);
      font-weight: 700;
      text-shadow: 0 0 12px var(--accent-color, #60a5fa),
                   0 0 24px rgba(96,165,250,0.3);
    }

    /* ---- Scene dots ---- */
    .scene-dots {
      position: fixed; bottom: 40px; left: 50%;
      transform: translateX(-50%);
      display: flex; gap: 10px; z-index: 100;
    }
    .scene-dots .dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: rgba(255,255,255,0.25); cursor: pointer;
      transition: all 0.3s;
    }
    .scene-dots .dot.active {
      background: var(--accent-color, #3b82f6);
      box-shadow: 0 0 8px var(--accent-color, #3b82f6);
      transform: scale(1.3);
    }

    /* ================================================================
       CSS ANIMATIONS — 8 presets (LLM selects by name)
       ================================================================ */

    /* 1. typewriter — character-by-character reveal */
    .anim-typewriter {
      overflow: hidden;
      white-space: nowrap;
      border-right: 3px solid var(--accent-color, #3b82f6);
      width: 0;
      animation: typewriter 2s steps(20, end) 0.3s forwards,
                 blink-caret 0.6s step-end infinite;
    }
    @keyframes typewriter {
      from { width: 0; }
      to { width: 100%; }
    }
    @keyframes blink-caret {
      50% { border-color: transparent; }
    }

    /* 2. fade_in — simple opacity */
    .anim-fade_in {
      opacity: 0;
      animation: fadeIn 1s ease 0.3s forwards;
    }
    @keyframes fadeIn {
      to { opacity: 1; }
    }

    /* 3. fade_in_up — fade + translate Y */
    .anim-fade_in_up {
      opacity: 0;
      transform: translateY(40px);
      animation: fadeInUp 0.8s ease 0.6s forwards;
    }
    @keyframes fadeInUp {
      to { opacity: 1; transform: translateY(0); }
    }

    /* 4. slide_up_stagger — lines slide up one by one */
    .anim-slide_up_stagger .line {
      opacity: 0;
      transform: translateY(60px);
      animation: slideUpLine 0.6s ease forwards;
    }
    .anim-slide_up_stagger .line:nth-child(1) { animation-delay: 0.8s; }
    .anim-slide_up_stagger .line:nth-child(2) { animation-delay: 1.3s; }
    .anim-slide_up_stagger .line:nth-child(3) { animation-delay: 1.8s; }
    @keyframes slideUpLine {
      to { opacity: 1; transform: translateY(0); }
    }

    /* 5. glow_pulse — highlighted words glow */
    .anim-glow_pulse .highlight-word {
      animation: glowPulse 2s ease-in-out infinite;
    }
    @keyframes glowPulse {
      0%, 100% {
        text-shadow: 0 0 12px var(--accent-color, #60a5fa),
                     0 0 24px rgba(96,165,250,0.3);
      }
      50% {
        text-shadow: 0 0 20px var(--accent-color, #60a5fa),
                     0 0 40px rgba(96,165,250,0.6),
                     0 0 60px rgba(96,165,250,0.3);
      }
    }

    /* 6. kenburns_zoom — slow zoom in */
    .anim-kenburns_zoom {
      animation: kbZoom 10s ease-in-out forwards;
    }
    @keyframes kbZoom {
      from { transform: scale(1); }
      to { transform: scale(1.15); }
    }

    /* 7. kenburns_pan — slow pan */
    .anim-kenburns_pan {
      animation: kbPan 10s ease-in-out forwards;
    }
    @keyframes kbPan {
      from { transform: translate(0, 0) scale(1.1); }
      to { transform: translate(-30px, -20px) scale(1.1); }
    }

    /* 8. scale_bounce — elastic scale entrance */
    .anim-scale_bounce {
      opacity: 0;
      transform: scale(0.3);
      animation: scaleBounce 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s forwards;
    }
    @keyframes scaleBounce {
      to { opacity: 1; transform: scale(1); }
    }
  </style>
</head>
<body>
  {% for scene in scenes %}
  <div class="scene {{ 'active' if loop.first else '' }}"
       data-index="{{ loop.index0 }}"
       data-duration="{{ scene.duration | default(8) }}"
       data-notes="{{ scene.notes | default('') | e }}"
       style="background-color: {{ scene.background_color | default('#0a0a1a') }};
              --accent-color: {{ scene.accent_color | default('#3b82f6') }};">

    {# ---- Top text zone ---- #}
    <div class="top-zone">
      {% set top = scene.top_text | default({}) %}
      <h1 class="anim-{{ top.headline_animation | default('typewriter') }}">
        {{ top.headline | default('') }}
      </h1>
      {% if top.subline %}
      <div class="subline anim-{{ top.subline_animation | default('fade_in_up') }}">
        {{ top.subline }}
      </div>
      {% endif %}
    </div>

    {# ---- Visual zone ---- #}
    {% set vis = scene.visual | default({}) %}
    <div class="visual-zone anim-{{ vis.animation | default('kenburns_zoom') }}"
         style="background: {{ vis.gradient | default('linear-gradient(135deg, #1a1a2e, #16213e, #0f3460)') }};">
      {% if vis.icon %}
      <div class="icon anim-scale_bounce">{{ vis.icon }}</div>
      {% endif %}
      {% if vis.description %}
      <div class="description anim-fade_in">{{ vis.description }}</div>
      {% endif %}
    </div>

    {# ---- Bottom text zone ---- #}
    {% set bot = scene.bottom_text | default({}) %}
    <div class="bottom-zone anim-{{ bot.animation | default('slide_up_stagger') }}">
      {% for line_item in bot.lines | default([]) %}
      <div class="line">
        {#- Replace highlight words with <span class="highlight-word"> -#}
        {% set text = line_item.text | default('') %}
        {% set highlights = line_item.highlights | default([]) %}
        {% if highlights %}
          {% set ns = namespace(result=text) %}
          {% for hw in highlights %}
            {% set ns.result = ns.result | replace(hw, '<span class="highlight-word">' ~ hw ~ '</span>') %}
          {% endfor %}
          {{ ns.result | safe }}
        {% else %}
          {{ text }}
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}

  {# ---- Scene indicator dots ---- #}
  {% if scenes | length > 1 %}
  <div class="scene-dots">
    {% for scene in scenes %}
    <div class="dot {{ 'active' if loop.first else '' }}" data-index="{{ loop.index0 }}"></div>
    {% endfor %}
  </div>
  {% endif %}

  <script>
    (function() {
      var scenes = document.querySelectorAll('.scene');
      var dots = document.querySelectorAll('.dot');
      var current = 0;
      var autoTimer = null;
      var isInIframe = window.parent !== window;

      function resetAnimations(sceneEl) {
        // Force re-trigger CSS animations by removing and re-adding classes
        var animated = sceneEl.querySelectorAll('[class*="anim-"]');
        animated.forEach(function(el) {
          el.style.animation = 'none';
          el.offsetHeight; // trigger reflow
          el.style.animation = '';
        });
      }

      function show(idx) {
        scenes.forEach(function(s, i) {
          s.classList.toggle('active', i === idx);
        });
        dots.forEach(function(d, i) {
          d.classList.toggle('active', i === idx);
        });
        current = idx;
        resetAnimations(scenes[idx]);
      }

      function next() {
        if (current < scenes.length - 1) {
          show(current + 1);
          scheduleAuto();
        } else {
          clearTimeout(autoTimer);
          if (isInIframe) {
            window.parent.postMessage({type: 'scene-complete'}, '*');
          }
        }
      }

      function scheduleAuto() {
        clearTimeout(autoTimer);
        var dur = parseFloat(scenes[current].getAttribute('data-duration') || '8');
        autoTimer = setTimeout(next, dur * 1000);
      }

      // Click to advance
      document.body.addEventListener('click', function(e) {
        if (e.target.classList.contains('dot')) {
          show(parseInt(e.target.getAttribute('data-index')));
          scheduleAuto();
        } else {
          next();
        }
      });

      // Keyboard navigation
      document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowRight' || e.key === ' ') { next(); }
        if (e.key === 'ArrowLeft' && current > 0) { show(current - 1); scheduleAuto(); }
      });

      // Listen for commands from parent iframe
      window.addEventListener('message', function(e) {
        if (e.data && e.data.type === 'play') { scheduleAuto(); }
        if (e.data && e.data.type === 'pause') { clearTimeout(autoTimer); }
        if (e.data && e.data.type === 'reset') { show(0); scheduleAuto(); }
      });

      // Auto-start
      scheduleAuto();
    })();
  </script>
</body>
</html>
