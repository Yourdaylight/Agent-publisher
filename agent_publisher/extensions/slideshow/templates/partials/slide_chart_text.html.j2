{% set pos = slide.content.chart_position | default('left') if slide.content else 'left' %}
<h2>{{ slide.title | default('') }}</h2>
<div class="slide-grid--chart-text {{ 'chart-right' if pos == 'right' else '' }}">
  {% if pos != 'right' %}
  <div>
    <div id="{{ slide.chart_id | default('chart_unknown') }}" class="chart-container" style="width:100%; height:350px;"></div>
  </div>
  <div>
    {% if slide.content and slide.content.text_content %}
    <h3>{{ slide.content.text_content.heading | default('') }}</h3>
    <ul>
      {% for item in slide.content.text_content['items'] | default([]) %}
      <li>{{ item.text }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
  {% else %}
  <div>
    {% if slide.content and slide.content.text_content %}
    <h3>{{ slide.content.text_content.heading | default('') }}</h3>
    <ul>
      {% for item in slide.content.text_content['items'] | default([]) %}
      <li>{{ item.text }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
  <div>
    <div id="{{ slide.chart_id | default('chart_unknown') }}" class="chart-container" style="width:100%; height:350px;"></div>
  </div>
  {% endif %}
</div>
